{
  "name": "eterecitizen",
  "private": true,
  "description": "Open protocol for AI agent identity, trust, and commerce",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean"
  },
  "keywords": [
    "ai-agents",
    "did",
    "verifiable-credentials",
    "identity",
    "trust",
    "reputation",
    "blockchain",
    "base"
  ],
  "author": "Icaro Holding",
  "homepage": "https://eterecitizen.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/icaroholding/EtereCitizen.git"
  },
  "bugs": {
    "url": "https://github.com/icaroholding/EtereCitizen/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
