{
  "name": "@eterecitizen/common",
  "version": "0.1.2",
  "description": "Shared types, schemas, and constants for EtereCitizen protocol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icaroholding/EtereCitizen.git",
    "directory": "packages/common"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "Apache-2.0"
}
