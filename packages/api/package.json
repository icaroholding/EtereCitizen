{
  "name": "@eterecitizen/api",
  "version": "0.1.0",
  "description": "Hono API server for EtereCitizen protocol",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@eterecitizen/sdk": "workspace:*",
    "@hono/node-server": "^1.11.0",
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "license": "Apache-2.0"
}
