{
  "name": "@eterecitizen/sdk",
  "version": "0.1.0",
  "description": "Core TypeScript SDK for EtereCitizen protocol — AI agent identity, trust, and commerce",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@eterecitizen/common": "workspace:*",
    "@veramo/core": "^7.0.0",
    "@veramo/credential-jwt": "7",
    "@veramo/credential-w3c": "^7.0.0",
    "@veramo/data-store": "^7.0.0",
    "@veramo/did-manager": "^7.0.0",
    "@veramo/did-provider-ethr": "^7.0.0",
    "@veramo/did-resolver": "^7.0.0",
    "@veramo/key-manager": "^7.0.0",
    "@veramo/kms-local": "^7.0.0",
    "better-sqlite3": "^11.0.0",
    "did-resolver": "^4.1.0",
    "ethr-did-resolver": "^10.1.0",
    "typeorm": "^0.3.28",
    "viem": "^2.15.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "license": "Apache-2.0"
}
