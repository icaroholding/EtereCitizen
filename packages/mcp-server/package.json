{
  "name": "@eterecitizen/mcp-server",
  "version": "0.1.0",
  "description": "MCP Server for EtereCitizen agent-to-agent verification",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icaroholding/EtereCitizen.git",
    "directory": "packages/mcp-server"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "eterecitizen-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@eterecitizen/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "license": "Apache-2.0"
}
