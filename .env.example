# Base network RPC URLs
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deploy
DEPLOYER_PRIVATE_KEY=0x...

# BaseScan verification
BASESCAN_API_KEY=

# Deployed contract address
ETERECITIZEN_CONTRACT_ADDRESS=0xf0fe3326cCab970F62F9639eCdeec028F050261d

# API key auth (comma-separated, leave empty for dev mode)
ETERECITIZEN_API_KEYS=

# Veramo (auto-generated if not set)
VERAMO_SECRET_KEY=

# IPFS (Pinata)
PINATA_API_KEY=
PINATA_SECRET_KEY=

# API server
PORT=3000
NODE_ENV=production
CORS_ORIGINS=https://eterecitizen.io,https://www.eterecitizen.io

# Web verifier
NEXT_PUBLIC_API_URL=https://api.eterecitizen.io/api

# Wallet adapters (optional - only needed for non-standard adapters)
CDP_API_KEY=
OPENFORT_API_KEY=
MOONPAY_API_KEY=
CONWAY_API_KEY=
