{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eterecitizen.ai/spec/schemas/payment-request.schema.json",
  "title": "EtereCitizen Payment Request",
  "description": "An out-of-band RPC payload sent by a paying Agent to a receiving Agent. See SPEC.md §12.2.",
  "type": "object",
  "required": ["recipientDID", "amount", "currency", "network"],
  "properties": {
    "recipientDID": { "type": "string", "pattern": "^did:ethr:0x[0-9a-f]+:0x[a-fA-F0-9]{40}$" },
    "amount":       { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "currency":     { "type": "string", "minLength": 1 },
    "network":      { "type": "string", "minLength": 1 },
    "description":  { "type": "string" }
  },
  "additionalProperties": false
}
