{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eterecitizen.ai/spec/schemas/vc-wallet-ownership.schema.json",
  "title": "EtereCitizen Wallet Ownership Verifiable Credential",
  "description": "Attests that the Agent controls a specific Ethereum address, without disclosing the address. See SPEC.md §6.5.",
  "type": "object",
  "required": ["@context", "type", "issuer", "issuanceDate", "credentialSubject"],
  "properties": {
    "@context": {
      "type": "array",
      "allOf": [
        { "contains": { "const": "https://www.w3.org/2018/credentials/v1" } },
        { "contains": { "const": "https://eterecitizen.ai/ns/vc/wallet-ownership/v1" } }
      ]
    },
    "id":   { "type": "string" },
    "type": {
      "type": "array",
      "allOf": [
        { "contains": { "const": "VerifiableCredential" } },
        { "contains": { "const": "EtereCitizenWalletOwnership" } }
      ]
    },
    "issuer": {
      "oneOf": [
        { "type": "string", "pattern": "^did:ethr:0x[0-9a-f]+:0x[a-fA-F0-9]{40}$" },
        { "type": "object", "required": ["id"], "properties": { "id": { "type": "string" } } }
      ]
    },
    "issuanceDate":   { "type": "string", "format": "date-time" },
    "expirationDate": { "type": "string", "format": "date-time" },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "walletProvider", "connectedAt", "challengeHash"],
      "properties": {
        "id":             { "type": "string", "pattern": "^did:ethr:0x[0-9a-f]+:0x[a-fA-F0-9]{40}$" },
        "walletProvider": { "type": "string", "enum": ["standard", "coinbase-cdp", "openfort", "moonpay", "conway"] },
        "connectedAt":    { "type": "string", "format": "date-time" },
        "challengeHash":  { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" }
      }
    },
    "proof": { "type": "object" }
  }
}
